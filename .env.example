# 프론트엔드(Vite) 환경 변수 템플릿
# 실제 사용 시 이 파일을 .env 로 복사한 뒤 값을 채우세요.
#   cp .env.example .env

# 랭킹 등록/조회용 Cloudflare Worker URL (배포 후 설정)
# 예: https://pokemon-master-worker.your-subdomain.workers.dev
VITE_WORKER_URL=

# 랭킹 조회용 GitHub raw URL (Worker 없이 조회만 가능)
# 예: https://raw.githubusercontent.com/{owner}/{repo}/main/data/rankings.json
VITE_RANKINGS_RAW_URL=

# 멀티플레이 WebSocket URL (5단계)
VITE_WS_URL=

# GitHub Pages base 경로 (보통 CI에서 자동 설정, 로컬은 비워두면 /)
# 프로젝트 Pages: /repo-name/  |  사용자 Pages(username.github.io): /
VITE_BASE=
